{
  "env": { "browser": true, "node": true, "webextensions": true, "jest": true, "es2022": true },
  "extends": ["eslint:recommended"],
  "parserOptions": { "ecmaVersion": 2022, "sourceType": "script" },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "eqeqeq": "error",
    "curly": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-var": "error",
    "prefer-const": "warn",
    "no-throw-literal": "error",
    "complexity": ["warn", 15],
    "max-depth": ["warn", 5],
    "max-lines-per-function": ["warn", 200]
  },
  "ignorePatterns": ["node_modules/", "coverage/", "dist/", "icons/", "bridge/"]
}
