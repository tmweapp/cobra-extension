{
  "manifest_version": 3,
  "name": "COBRA",
  "version": "5.2.0",
  "description": "COBRA — AI Co-Pilot Browser. Scraping, Agent, Knowledge Base, Gate System, File Creator. Side Panel con memoria, apprendimento e intelligenza operativa.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "downloads",
    "alarms",
    "nativeMessaging",
    "sidePanel",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none';"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "minimum_chrome_version": "114",
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "icons/agents/*",
        "sidepanel.html",
        "sidepanel-canvas.html",
        "sidepanel-canvas-app.js",
        "onboarding.js",
        "content.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
