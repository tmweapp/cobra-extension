{
  "banking": {
    "domains": [
      "paypal.com", "stripe.com", "wise.com", "revolut.com",
      "visa.com", "mastercard.com", "n26.com",
      "fineco.it", "intesasanpaolo.com", "unicredit.it",
      "bnl.it", "mediolanum.it", "postepay.it"
    ],
    "rule": "read-only",
    "description": "Banking domains: write operations blocked"
